{
  "job_type": "integration_hub.phase2.diagnostics",
  "goal": "Check local execution prerequisites",
  "inputs": {
    "message": "Run diagnostics before enabling external execution",
    "target_path": ".ai-runs/{{run_id}}/diagnostics_report.json"
  },
  "constraints": {
    "allowed_paths": [
      ".ai-runs/"
    ],
    "max_files_changed": 0,
    "no_destructive_ops": true
  },
  "acceptance_criteria": [
    "Diagnostics report is saved under .ai-runs/<run_id>/diagnostics_report.json",
    "checks/logs capture command availability and env status"
  ],
  "provenance": {
    "issue": "https://github.com/example/repo/issues/21",
    "operator": "operator"
  },
  "run_mode": "local",
  "output_language": "ja",
  "expected_artifacts": [
    {
      "name": "diagnostics_report.json",
      "description": "Diagnostics report"
    }
  ]
}
